# Gmail account used to SEND alerts. Must have an App Password configured.
# https://support.google.com/accounts/answer/185833
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Destination for alert emails (can be the same as GMAIL_USER)
ALERT_TO=your.address@gmail.com

# SQLite file path (relative to project root is fine)
DB_PATH=app.db

# Flask secret for flashing messages
FLASK_SECRET=change-me
